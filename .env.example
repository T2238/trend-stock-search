# .env.example — このファイルをコピーして .env を作成してください

# =============================
# Claude API (任意)
# https://console.anthropic.com でAPIキーを取得
# 設定するとAI高精度分析モードが有効になります
# =============================
CLAUDE_API_KEY=

# =============================
# J-Quants API V2 (任意・推奨)
# https://jpx-jquants.com にログイン → ダッシュボード → APIキー発行
# ※ 2025年12月22日以降登録ユーザーは V2 APIキー方式
# 設定すると東証全銘柄リスト(~3,900社)を自動取得できます
# 未設定の場合はサンプル銘柄リストで動作します
# =============================
JQUANTS_API_KEY=
